def resolve_page_name(agent_id, flow_display_name, page_display_name):
    try:
        flows_client = Flows(agent_id=agent_id)
        all_flows = flows_client.list_flows()
        flow = next((f for f in all_flows if f.display_name == flow_display_name), None)
        if not flow:
            print(f"[PAGE] ⚠️  Flow '{flow_display_name}' not found")
            return None
        print(f"[PAGE] ✅ Flow: {flow.name}")

        # ← Fix: Pages takes flow_id, not agent_id
        pages_client = Pages(flow_id=flow.name)
        all_pages = pages_client.list_pages()
        page = next((p for p in all_pages if p.display_name == page_display_name), None)
        if not page:
            print(f"[PAGE] ⚠️  Page '{page_display_name}' not found")
            return None
        print(f"[PAGE] ✅ Page: {page.name}")
        return page.name

    except Exception as e:
        print(f"[PAGE] ❌ Error: {e}")
        return None


